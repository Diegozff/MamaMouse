# ──────────────────────────────────────────────────────────
# Mama Mouse – Variables de entorno
# Copiá este archivo como ".env" y completá tus credenciales
# ──────────────────────────────────────────────────────────

# Admin password (panel ?admin)
VITE_ADMIN_PASS=mamamouse

# URL pública de la app (para links en emails/WhatsApp)
APP_URL=http://localhost:5173

# ── Email (SMTP) ───────────────────────────────────────────
# Opción 1: Gmail con App Password
#   1. Activá verificación en 2 pasos en tu cuenta Google
#   2. Entrá a: myaccount.google.com/apppasswords
#   3. Generá una App Password para "Mail"
#   4. Pegala en SMTP_PASS (sin espacios)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tumismo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=Mama Mouse <tumismo@gmail.com>

# Opción 2: Otro proveedor SMTP (Hostinger, GoDaddy, etc.)
# SMTP_HOST=mail.tudominio.com
# SMTP_PORT=587
# SMTP_USER=reservas@tudominio.com
# SMTP_PASS=tupassword

# ── WhatsApp (Twilio) ──────────────────────────────────────
# 1. Creá cuenta en https://www.twilio.com (es gratis para sandbox)
# 2. Activá el sandbox de WhatsApp: console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 3. Pedí a cada viajero que envíe "join <tu-sandbox-code>" a +14155238886
# 4. En producción: solicitá un número propio en Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
